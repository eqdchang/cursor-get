{
  "name": "header-footer-clone-template",
  "version": "0.4.0",
  "private": true,
  "description": "Extract any site's header and footer as self-contained drop-in JS bundles. Next.js provides a preview harness; bundles/ produces the shippable artifacts.",
  "author": "JCodesMore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JCodesMore/ai-website-cloner-template.git"
  },
  "homepage": "https://github.com/JCodesMore/ai-website-cloner-template",
  "bugs": {
    "url": "https://github.com/JCodesMore/ai-website-cloner-template/issues"
  },
  "keywords": [
    "claude-code",
    "website-clone",
    "header",
    "footer",
    "drop-in",
    "nextjs",
    "ai",
    "tailwindcss"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "bundles:build": "npm --prefix bundles run build",
    "bundles:build:all": "npm --prefix bundles run build:all",
    "bundles:dev": "npm --prefix bundles run dev"
  },
  "dependencies": {
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
